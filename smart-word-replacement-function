function myReplace(str, wrd, replacement) {
  let capRegex = /^[A-Z]+/g;
  let isWordCap = capRegex.test(wrd);

  if (isWordCap) {
    replacement = replacement[0].toUpperCase() + replacement.slice(1);
  } else {
    replacement = replacement.toLowerCase();
  }

  return str.replace(wrd, replacement);
}
