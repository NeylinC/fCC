class BankAccount {
    constructor() {
        this.balance = 0;
        this.transactions = [];
    }

    deposit(depAmnt) {
        if (depAmnt > 0) {
            this.transactions.push({
                'type': 'deposit',
                'amount': depAmnt
            });
            this.balance += depAmnt;
            return `Successfully deposited $${depAmnt}. New balance: $${this.balance}`

        } else {
            return "Deposit amount must be greater than zero."
        }
    }

    withdraw(witAmnt) {
        if (witAmnt > 0 && witAmnt <= this.balance) {
            this.transactions.push({
                'type': 'withdraw',
                'amount': witAmnt
            });
            this.balance -= witAmnt;
            return `Successfully withdrew $${witAmnt}. New balance: $${this.balance}`

        } else {
            return "Insufficient balance or invalid amount."
        }
    }

    checkBalance() {
        return `Current balance: $${this.balance}`
    };

    listAllDeposits() {
        return `Deposits: ` + `${this.transactions.filter(e=> e.type == 'deposit').map(e => e.amount).toString() }`
    }

    listAllWithdrawals() {
        return `Withdrawals: ` + `${this.transactions.filter(e=> e.type == 'withdraw').map(e => e.amount).toString() }`
    }
}


// testing
const myAccount = new BankAccount();

myAccount.deposit(100)
myAccount.deposit(20)
myAccount.withdraw(5)
myAccount.withdraw(1)
